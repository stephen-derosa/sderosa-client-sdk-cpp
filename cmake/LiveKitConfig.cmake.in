@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(spdlog)

include("${CMAKE_CURRENT_LIST_DIR}/LiveKitTargets.cmake")

if(TARGET LiveKit::livekit)
  get_target_property(_livekit_links LiveKit::livekit INTERFACE_LINK_LIBRARIES)
  if(NOT _livekit_links)
    set_property(TARGET LiveKit::livekit PROPERTY INTERFACE_LINK_LIBRARIES "spdlog::spdlog")
  else()
    set(_livekit_link_list ${_livekit_links})
    list(FIND _livekit_link_list "spdlog::spdlog" _livekit_spdlog_index)
    if(_livekit_spdlog_index EQUAL -1)
      set_property(TARGET LiveKit::livekit APPEND PROPERTY INTERFACE_LINK_LIBRARIES "spdlog::spdlog")
    endif()
  endif()
endif()
